generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionKind {
  direct
  ai
}

enum MessageAssetKind {
  link
  doc
  media
}

enum CallStatus {
  active
  ended
}

model User {
  id        String               @id
  email     String?              @unique
  name      String?
  avatarUrl String?
  isAi      Boolean              @default(false)
  createdAt DateTime             @default(now())

  participants SessionParticipant[]
  messages     Message[]          @relation("SentMessages")
}

model Session {
  id        String               @id @default(cuid())
  kind      SessionKind          @default(direct)
  directKey String?              @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  participants SessionParticipant[]
  messages     Message[]
  calls        Call[]
}

model SessionParticipant {
  sessionId   String
  userId      String
  joinedAt    DateTime @default(now())
  isArchived  Boolean  @default(false)
  isMuted     Boolean  @default(false)
  lastReadAt  DateTime?
  clearedAt   DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  isAi      Boolean  @default(false)
  reactions Json?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User    @relation("SentMessages", fields: [senderId], references: [id], onDelete: Restrict)
  assets  MessageAsset[]

  @@index([sessionId, createdAt])
  @@index([senderId, createdAt])
}

model MessageAsset {
  id          String           @id @default(cuid())
  messageId   String
  kind        MessageAssetKind
  createdAt   DateTime         @default(now())
  url         String?
  title       String?
  description String?
  accent      String?
  name        String?
  meta        String?
  short       String?
  tone        String?
  month       String?
  fileUrl     String?
  fileSize    Int?
  mimeType    String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, kind])
  @@index([kind, createdAt])
}

model Call {
  id         String     @id @default(cuid())
  sessionId  String
  roomName   String     @unique
  status     CallStatus @default(active)
  startedAt  DateTime   @default(now())
  endedAt    DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
}
